<?xml version="1.0"?>
<robot name="hands_one">

  <!-- Connect base_link to the world so it stays fixed in space -->
  <link name="world"/>

  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.5" rpy="1.5708 0 0"/>
  </joint>

  <link name="base_link"/>

  <gazebo reference="base_link">
    <static>true</static>
  </gazebo>

  <joint name="base_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="PalmMid_link"/>
  </joint>

  <!-- Palm Mid link -->
  <link name="PalmMid_link">
    <visual>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmMidUpdated.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmMidUpdated.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="PalmMid_link"> 
    <material>Gazebo/Gray</material> 
    <gravity>false</gravity> 
  </gazebo>

  <!-- Palm Back link -->
  <link name="PalmBackCover_link">
    <visual>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmBackCoverUpdated.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmBackCoverUpdated.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Palm Front link -->
  <link name="PalmFrontCover_link">
    <visual>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmFrontCover.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmFrontCover.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Joint connecting PalmBackCover to PalmMid -->
  <joint name="PalmBack_joint" type="fixed">
    <parent link="PalmMid_link"/>
    <child link="PalmBackCover_link"/>
    <origin xyz="0 -0.0050 -0.0075" rpy="0 0 0"/>
  </joint>

  <!-- Joint connecting PalmFrontCover to PalmMid -->
  <joint name="PalmFront_joint" type="fixed">
    <parent link="PalmMid_link"/>
    <child link="PalmFrontCover_link"/>
    <origin xyz="0 -0.0050 0.0175" rpy="0 0 0"/>
  </joint>

  <!-- Little Finger Servo -->
  <link name="LittleServo_link">
    <visual>
      <geometry>
        <mesh filename="package://hands_one/meshes/servo.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://hands_one/meshes/servo.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Ring Finger Servo -->
  <link name="RingServo_link">
    <visual>
      <geometry>
        <mesh filename="package://hands_one/meshes/servo.stl" scale="0.001 0.001 0.001"/>
