<?xml version="1.0"?>
<robot name="hands_one">

  <link name="base_link"/>

  <joint name="base_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="PalmMid_link"/>
  </joint>

  <!-- Palm Mid link -->
  <link name="PalmMid_link">
    <visual>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmMid.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmMid.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="PalmMid_link"> 
    <material>Gazebo/Gray</material> 
    <gravity>false</gravity> 
  </gazebo>

  <!-- Palm Back link -->
  <link name="PalmBackCover_link">
    <visual>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmBackCoverUpdated.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://hands_one/meshes/PalmBackCoverUpdated.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Palm Front link -->
