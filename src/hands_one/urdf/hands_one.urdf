  <joint name="LittleMechanism_joint" type="revolute">
    <parent link="LittleServo_link"/>
    <child link="LittleMechanism_link"/>
    <origin xyz="0.0054 0.0175 0" rpy="-1.5708 -1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.1" upper="0.52" effort="1" velocity="1"/>
    <dynamics damping="0.5" friction="0.2"/>
