    <origin xyz="0.01924 -0.03931 0.01795" rpy="1.5708 0 0.7854"/>
    <dynamics damping="0.5" friction="0.2"/>
  </joint>

  <!-- Little Abduction Mechanism -->
  <link name="LittleMechanism_link">
    <visual>
      <origin xyz="0 0.0157 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://hands_one/meshes/AbductionMechanism.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
